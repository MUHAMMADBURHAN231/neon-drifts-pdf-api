# Port — Render sets this automatically, leave as is
PORT=3001

# Shared secret — must match PDF_API_SECRET in the dashboard .env
PDF_API_SECRET=change_this_to_a_long_random_secret

# Comma-separated list of allowed origins (your Vercel URL)
# Use * during development only
ALLOWED_ORIGINS=https://neon-drifts-dashboard.vercel.app,https://your-custom-domain.com
